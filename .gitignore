node_modules/
dist/
dist-ssr/
build/
*.local

# --- Секреты (Критично!) ---
# Скрывает все файлы .env во всех подпапках
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Специфично для Prisma ---
