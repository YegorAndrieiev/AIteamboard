{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node", // Для сервера тільки Node!
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "types": ["node"] // Прибираємо vite/client, тут він не потрібен
  },
  "include": ["src/**/*", "prisma.config.ts"]
}
